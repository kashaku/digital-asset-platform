PORT=3001
RPC_URL=http://127.0.0.1:8545

# Filled by the deployment script or set manually.
NFT_ADDRESS=
FIXED_PRICE_ADDRESS=
OFFER_ADDRESS=

# Local Kubo IPFS node. Used when PINATA_JWT is empty.
IPFS_API_URL=http://127.0.0.1:5001
IPFS_GATEWAY_URL=http://127.0.0.1:8080

# Optional Pinata mode. If set, uploads use Pinata instead of local Kubo.
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud
